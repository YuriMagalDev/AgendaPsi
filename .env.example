VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Evolution API — server-side only (set via: supabase secrets set KEY=value)
EVOLUTION_API_URL=https://your-evolution-api.example.com
EVOLUTION_API_KEY=your-global-api-key
WEBHOOK_SECRET=generate-a-random-32-char-string

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://<project-ref>.supabase.co/functions/v1/google-calendar-auth?action=callback
APP_URL=https://your-app.vercel.app
